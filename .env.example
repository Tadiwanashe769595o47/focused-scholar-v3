# ============================================
# Focused Scholar V3 - Configuration
# ============================================
# Copy this file to .env and fill in your values

# Supabase (REQUIRED - create your own project at supabase.com)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Frontend Supabase (Vite requires VITE_ prefix)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server
PORT=3000
NODE_ENV=production

# JWT Secret (CHANGE THIS to something unique)
JWT_SECRET=change-this-to-your-own-secret-key

# Access Codes (change as needed)
TEACHER_ACCESS_CODE=123456
HOLIDAY_ACCESS_CODE=789012
PARENT_ACCESS_CODE=parent123

# Optional: AI API Keys (for Tutor feature)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: Local AI (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
GEMMA_ENABLED=false
